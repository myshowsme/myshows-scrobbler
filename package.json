{
  "name": "myshows-scrobbler",
  "version": "0.0.13",
  "description": "Universal media scrobbler for MyShows (Plex, Emby, Jellyfin, Kodi)",
  "keywords": [
    "emby",
    "jellyfin",
    "kodi",
    "myshows",
    "plex",
    "scrobble"
  ],
  "homepage": "https://github.com/myshowsme/myshows-scrobbler#readme",
  "bugs": {
    "url": "https://github.com/myshowsme/myshows-scrobbler/issues"
  },
  "license": "MIT",
  "author": "MyShows",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/myshowsme/myshows-scrobbler.git"
  },
  "type": "module",
  "main": "dist/server/index.mjs",
  "scripts": {
    "dev": "portless --name myshows-scrobbler --script dev:server",
    "dev:server": "tsx watch src/index.ts",
    "dev:server:direct": "cross-env PORT=5172 tsx watch src/index.ts",
    "dev:ui": "vp dev ui --port 5173",
    "dev:ui:server": "vp dev ui",
    "dev:ui:backend": "cross-env SCROBBLER_BACKEND_PORT=5172 vp run dev:ui",
    "dev:ui:portless": "cross-env SCROBBLER_BACKEND_PORT=5172 portless --name myshows-scrobbler-ui --script dev:ui:server",
    "dev:all": "concurrently --kill-others-on-fail --names backend,ui \"vp run dev:server:direct\" \"vp run dev:ui:backend\"",
    "build": "vp pack",
    "build:ui": "vp build ui",
    "build:all": "vp run build && vp run build:ui",
    "build:electron": "vp run build:all && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false node scripts/run-electron-builder.mjs",
    "build:electron:dir": "vp run build:all && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false node scripts/run-electron-builder.mjs --dir",
    "electron": "vp run build:all && electron dist/electron/electron.mjs",
    "start": "node dist/server/index.mjs",
    "start:ui": "node dist/server/index.mjs --ui",
    "check": "vp check",
    "check:fix": "vp check --fix",
    "test": "vp test run",
    "test:watch": "vp test",
    "release": "node scripts/release.mjs",
    "generate:ui-types": "node scripts/generate-ui-types.mjs",
    "check:ui-types": "node scripts/generate-ui-types.mjs --check",
    "pretest:e2e": "vp run build:all",
    "test:e2e": "playwright test",
    "test:all": "vp run test && vp run test:e2e",
    "prepare": "vp config"
  },
  "dependencies": {
    "@fastify/websocket": "11.3.0",
    "@ffprobe-installer/ffprobe": "2.1.2",
    "electron-updater": "6.8.9",
    "fastify": "5.10.0",
    "guessit-js": "4.0.0",
    "koffi": "3.1.2"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1",
    "@types/node": "26.1.1",
    "@types/ws": "8.18.1",
    "@vitejs/plugin-vue": "6.0.8",
    "@vitest/ui": "4.1.10",
    "concurrently": "10.0.3",
    "cross-env": "10.1.0",
    "electron": "43.2.0",
    "electron-builder": "26.15.3",
    "portless": "0.15.4",
    "sass": "1.101.3",
    "tsx": "4.23.1",
    "typescript": "6.0.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.5",
    "vite-plus": "0.2.5",
    "vitest": "4.1.10",
    "vue": "3.5.40",
    "vue-i18n": "11.4.7",
    "vue-tsc": "3.3.7"
  },
  "optionalDependencies": {
    "@fastify/static": "10.1.2"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=11.0.0"
  },
  "packageManager": "pnpm@11.16.0+sha512.b767e9a98fc87aec0f42daefcd0e84941c2cdb45d73c4e1e68860fb2bdfdbe032ab592105479e5e05c237f740c8a5ffdbbb52385797ddc2296745a1bbb883e8d",
  "build": {
    "appId": "me.myshows.scrobbler",
    "productName": "MyShows Scrobbler",
    "directories": {
      "output": "release"
    },
    "publish": {
      "provider": "github",
      "owner": "myshowsme",
      "repo": "myshows-scrobbler"
    },
    "files": [
      "dist/electron/**",
      "dist/ui/**",
      "package.json",
      "!node_modules/**",
      "node_modules/koffi/**",
      "node_modules/@koromix/**",
      "node_modules/@ffprobe-installer/**"
    ],
    "afterPack": "scripts/after-pack.cjs",
    "extraMetadata": {
      "main": "dist/electron/electron.mjs"
    },
    "extraResources": [
      {
        "from": "assets/tray/tray-icon.png",
        "to": "tray-icon.png"
      },
      {
        "from": "assets/tray/tray-icon@2x.png",
        "to": "tray-icon@2x.png"
      },
      {
        "from": "assets/tray/trayTemplate.png",
        "to": "trayTemplate.png"
      },
      {
        "from": "assets/tray/trayTemplate@2x.png",
        "to": "trayTemplate@2x.png"
      },
      {
        "from": "assets/tray/app-icon.png",
        "to": "app-icon.png"
      },
      {
        "from": "scripts/macos-osa-probe.js",
        "to": "macos-osa-probe.js"
      },
      {
        "from": "scripts/windows-smtc-probe.ps1",
        "to": "windows-smtc-probe.ps1"
      },
      {
        "from": "scripts/windows-resolve-handle-path.ps1",
        "to": "windows-resolve-handle-path.ps1"
      }
    ],
    "asarUnpack": [
      "node_modules/koffi/**",
      "node_modules/@koromix/**",
      "node_modules/@ffprobe-installer/**"
    ],
    "npmRebuild": false,
    "mac": {
      "category": "public.app-category.entertainment",
      "icon": "build/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "build/icon.png",
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "category": "AudioVideo",
      "icon": "build/icon.png",
      "target": [
        "AppImage"
      ]
    }
  }
}
